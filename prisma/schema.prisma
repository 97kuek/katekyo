generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  teacher
  student
}

enum HomeworkStatus {
  assigned
  submitted
  approved
  rejected
}

enum LessonType {
  online
  offline
}

enum TestType {
  mock
  exam
  quiz
  other
}

enum GardenItemType {
  tree
  bush
  flower
  cherry
  big_tree
  bamboo
  mushroom
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  role       Role
  password   String
  lineUserId String?  @unique
  createdAt  DateTime @default(now())

  // teacher relations
  students            Student[]           @relation("TeacherStudents")
  inviteTokens        InviteToken[]
  subjects            Subject[]
  homeworksGiven      Homework[]          @relation("TeacherHomework")
  gradesGiven         GradeRecord[]       @relation("TeacherGrades")
  lessonsGiven        Lesson[]            @relation("TeacherLessons")
  materialsGiven      StudentMaterial[]   @relation("TeacherMaterials")
  examEventsGiven     ExamEvent[]         @relation("TeacherExamEvents")
  homeworkTemplates   HomeworkTemplate[]  @relation("TeacherTemplates")

  // student relation
  studentProfile Student?  @relation("StudentUser")

  lineLinkToken  LineLinkToken?
}

model LineLinkToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Student {
  id                   String   @id @default(uuid())
  userId               String   @unique
  teacherId            String
  grade                String
  gardenGeneration     Int      @default(1)
  defaultHourlyRate    Int?
  defaultTravelExpense Int?
  createdAt            DateTime @default(now())

  user       User              @relation("StudentUser", fields: [userId], references: [id], onDelete: Cascade)
  teacher    User              @relation("TeacherStudents", fields: [teacherId], references: [id])
  homeworks    Homework[]
  grades       GradeRecord[]
  lessons      Lesson[]
  materials    StudentMaterial[]
  examEvents   ExamEvent[]
  gardenItems  GardenItem[]

  @@index([teacherId])
}

model InviteToken {
  id        String    @id @default(uuid())
  token     String    @unique @default(uuid())
  teacherId String
  email     String?
  name      String
  grade     String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  teacher   User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([expiresAt])
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  teacherId String
  createdAt DateTime @default(now())

  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([name, teacherId])
  @@index([teacherId])
}

model Homework {
  id              String         @id @default(uuid())
  studentId       String
  teacherId       String
  title           String
  description     String?
  dueDate         DateTime
  subjectIds      String[]
  materialId      String?
  status          HomeworkStatus @default(assigned)
  studentNote      String?
  difficultyRating Int?
  teacherFeedback  String?
  photoUrl        String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())

  student  Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  User             @relation("TeacherHomework", fields: [teacherId], references: [id], onDelete: Cascade)
  material StudentMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([studentId])
  @@index([teacherId, status])
  @@index([dueDate])
}

model GradeRecord {
  id            String   @id @default(uuid())
  studentId     String
  teacherId     String
  testName      String
  date          DateTime
  subjectIds    String[]
  score         Int?
  maxScore      Int?
  rank          Int?
  totalStudents Int?
  deviation     Float?
  testType      TestType @default(other)
  avgScore      Int?
  teacherRating Int?
  comment       String?
  createdAt     DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher User    @relation("TeacherGrades", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([teacherId, testType])
  @@index([date])
}

model Lesson {
  id            String     @id @default(uuid())
  teacherId     String
  studentId     String
  date          DateTime
  durationMin   Int?
  type          LessonType @default(online)
  notes         String?
  lessonLog     String?
  hourlyRate    Int?
  travelExpense Int?
  createdAt     DateTime   @default(now())

  teacher User    @relation("TeacherLessons", fields: [teacherId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([teacherId, date])
}

model ExamEvent {
  id        String   @id @default(uuid())
  studentId String
  teacherId String
  name      String
  date      DateTime
  testType  TestType @default(exam)
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher User    @relation("TeacherExamEvents", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([date])
}

model GardenItem {
  id        String         @id @default(uuid())
  studentId String
  x         Int
  y         Int
  itemType  GardenItemType
  createdAt DateTime       @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, x, y])
  @@index([studentId])
}

model StudentMaterial {
  id        String   @id @default(uuid())
  studentId String
  teacherId String
  name      String
  note      String?
  createdAt DateTime @default(now())

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User       @relation("TeacherMaterials", fields: [teacherId], references: [id], onDelete: Cascade)
  homeworks Homework[]

  @@index([studentId])
  @@index([teacherId])
}

model HomeworkTemplate {
  id          String   @id @default(uuid())
  teacherId   String
  title       String
  description String?
  createdAt   DateTime @default(now())

  teacher User @relation("TeacherTemplates", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}
