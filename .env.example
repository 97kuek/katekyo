# Supabase PostgreSQL
# Supabase ダッシュボード > Settings > Database > Connection string から取得
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
# openssl rand -base64 32 で生成
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Google Cloud Console の OAuth 2.0 クライアント。両方設定した場合だけGoogleログインを有効化
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
